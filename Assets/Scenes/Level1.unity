  - "\u042F\u0447\u0435\u0439\u043A\u0438 \u0431\u044B\u0432\u0430\u044E\u0442 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432:\n\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435,
    \u0441\u0440\u0435\u0434\u043D\u0438\u0435 \u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u0435.\n\n\u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u044F\u0447\u0435\u0439\u043A\u0438 \u0442\u0440\u0435\u0431\u0443\u044E\u0442\n\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0439
    \u0446\u0432\u0435\u0442 \u043A\u0443\u0431\u0430.\n\n\u0415\u0441\u043B\u0438
    \u0446\u0432\u0435\u0442 \u043D\u0435 \u0432\u0430\u0436\u0435\u043D \u2014\n\u044F\u0447\u0435\u0439\u043A\u0430
    \u0431\u0443\u0434\u0435\u0442 \u043C\u0435\u043D\u044F\u0442\u044C \u0446\u0432\u0435\u0442."
  - "WASD \u2014 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043A\u0443\u0431\u043E\u0432\nR
