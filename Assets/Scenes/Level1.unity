    \u0443\u0440\u043E\u0432\u0435\u043D\u044C\n\r\nTab \u2014 \u0432\u044B\u0431\u0440\u0430\u0442\u044C
    \u043A\u0443\u0431\r\nSpace \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043A\u0443\u0431\r\nE \u2014 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u043A\u0443\u0431\u044B\r\n\r\n\u041A\u0443\u0431\u044B \u043C\u043E\u0433\u0443\u0442
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442\u044C \u0447\u0435\u0440\u0435\u0437
    \u0441\u0442\u0435\u043D\u044B\r\n\u0438 \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
    \u043F\u043E \u043A\u043B\u0435\u0442\u043A\u0430\u043C \u0441\u0432\u043E\u0435\u0433\u043E
    \u0446\u0432\u0435\u0442\u0430"
  - "\u0424\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u044B\u0435 \u0432\u043E\u0440\u043E\u0442\u0430
    \u2014\r\n\u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
    \u043A\u0443\u0431\u043E\u0432\r\n\r\n\u041E\u0440\u0430\u043D\u0436\u0435\u0432\u044B\u0435
    \u0432\u043E\u0440\u043E\u0442\u0430 \u2014\r\n\u0434\u043B\u044F \u043A\u0443\u0431\u043E\u0432
    \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u0430\r\n\r\n\u041A\u043D\u043E\u043F\u043A\u0438
    1, 2, 3, 0 \u2014\r\n\u0441\u043C\u0435\u043D\u0430 \u043A\u0430\u043C\u0435\u0440\u044B"
  - "\u0427\u0451\u0440\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u0438
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442\r\n\u043F\u0435\u0440\u0435\u0439\u0442\u0438
    \u043D\u0430 \u0441\u0442\u0435\u043D\u044B\r\n\r\n\u041E\u043D\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0441\u043B\u0438 \u043E\u0441\u0442\u0430\u043B\u0441\u044F\r\n\u043E\u0434\u0438\u043D
    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0439 \u043A\u0443\u0431"
  - "\u0426\u0435\u043B\u044C \u0443\u0440\u043E\u0432\u043D\u044F:\n1. \u0416\u0435\u043B\u0442\u044B\u0439
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u043A\u0443\u0431\u0438\u043A\n2.
    \u0421\u0438\u043D\u0438\u0439 \u043A\u0443\u0431\u0438\u043A \u043B\u044E\u0431\u043E\u0433\u043E
    \u0440\u0430\u0437\u043C\u0435\u0440\u0430\n3. \u0421\u0440\u0435\u0434\u043D\u0438\u0439
    \u043A\u0443\u0431\u0438\u043A \u043B\u044E\u0431\u043E\u0433\u043E \u0446\u0432\u0435\u0442\u0430"
