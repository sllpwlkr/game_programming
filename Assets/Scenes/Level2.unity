--- !u!114 &307353688
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 307353687}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 640c24af4a5a983499da28d47aca1f59, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LevelUIController
  gameManager: {fileID: 2064253762}
  introPanel: {fileID: 891703207}
  winPanel: {fileID: 976546950}
  pageText: {fileID: 1586657274}
  pageCounterText: {fileID: 631287451}
  backButton: {fileID: 802322577}
  nextButton: {fileID: 53419203}
  startButton: {fileID: 485056170}
  introPages:
  - "\u0426\u0435\u043B\u044C \u0443\u0440\u043E\u0432\u043D\u044F:\n1. \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u0436\u0435\u043B\u044B\u0439\n2. \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u0441\u0438\u043D\u0438\u0439\n3. \u0441\u0440\u0435\u0434\u043D\u0438\u0439
    \u0436\u0435\u043B\u0442\u044B\u0439"
  - "\u042F\u0447\u0435\u0439\u043A\u0438 \u0431\u044B\u0432\u0430\u044E\u0442 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432:\n\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435,
    \u0441\u0440\u0435\u0434\u043D\u0438\u0435 \u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u0435.\n\n\u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u044F\u0447\u0435\u0439\u043A\u0438 \u0442\u0440\u0435\u0431\u0443\u044E\u0442\n\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0439
    \u0446\u0432\u0435\u0442 \u043A\u0443\u0431\u0430.\n\n\u0415\u0441\u043B\u0438
    \u0446\u0432\u0435\u0442 \u043D\u0435 \u0432\u0430\u0436\u0435\u043D \u2014\n\u044F\u0447\u0435\u0439\u043A\u0430
    \u0431\u0443\u0434\u0435\u0442 \u043C\u0435\u043D\u044F\u0442\u044C \u0446\u0432\u0435\u0442."
  - "WASD \u2014 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043A\u0443\u0431\u043E\u0432\nR
    \u2014 \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C
    \u0443\u0440\u043E\u0432\u0435\u043D\u044C\n\r\nTab \u2014 \u0432\u044B\u0431\u0440\u0430\u0442\u044C
    \u043A\u0443\u0431\r\nSpace \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043A\u0443\u0431\r\nE \u2014 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u043A\u0443\u0431\u044B\r\n\r\n\u041A\u0443\u0431\u044B \u043C\u043E\u0433\u0443\u0442
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442\u044C \u0447\u0435\u0440\u0435\u0437
    \u0441\u0442\u0435\u043D\u044B\r\n\u0438 \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
    \u043F\u043E \u043A\u043B\u0435\u0442\u043A\u0430\u043C \u0441\u0432\u043E\u0435\u0433\u043E
    \u0446\u0432\u0435\u0442\u0430"
  - "\u0424\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u044B\u0435 \u0432\u043E\u0440\u043E\u0442\u0430
    \u2014\r\n\u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
    \u043A\u0443\u0431\u043E\u0432\r\n\r\n\u041E\u0440\u0430\u043D\u0436\u0435\u0432\u044B\u0435
    \u0432\u043E\u0440\u043E\u0442\u0430 \u2014\r\n\u0434\u043B\u044F \u043A\u0443\u0431\u043E\u0432
    \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u0430\r\n\r\n\u041A\u043D\u043E\u043F\u043A\u0438
    1, 2, 3, 0 \u2014\r\n\u0441\u043C\u0435\u043D\u0430 \u043A\u0430\u043C\u0435\u0440\u044B"
  - "\u0427\u0451\u0440\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u0438
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442\r\n\u043F\u0435\u0440\u0435\u0439\u0442\u0438
    \u043D\u0430 \u0441\u0442\u0435\u043D\u044B\r\n\r\n\u041E\u043D\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0441\u043B\u0438 \u043E\u0441\u0442\u0430\u043B\u0441\u044F\r\n\u043E\u0434\u0438\u043D
    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0439 \u043A\u0443\u0431"
  winText: {fileID: 561278903}
